# Application
APP_ENV=development
APP_NAME=AERIE
APP_VERSION=0.1.0
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Backend security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7
CONFIRMATION_TOKEN_TTL_MINUTES=10

# Application PostgreSQL
APP_POSTGRES_HOST=postgres
APP_POSTGRES_PORT=5432
APP_POSTGRES_DB=aerie_db
APP_POSTGRES_USER=aerie_user
APP_POSTGRES_PASSWORD=change-me

# Odoo PostgreSQL
ODOO_DB_HOST=odoo-db
ODOO_DB_PORT=5432
ODOO_DB=odoo
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=change-me

# Odoo JSON-RPC
ODOO_BASE_URL=http://odoo:8069
ODOO_USERNAME=admin
ODOO_PASSWORD=change-me
ODOO_RATE_LIMIT_PER_SECOND=10

# Redis
REDIS_URL=redis://redis:6379/0
SESSION_TTL_MINUTES=60

# OpenAI / LangChain / LangSmith
OPENAI_API_KEY=
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aerie-mvp

# Procurement scheduler
PROCUREMENT_MONITORING_INTERVAL_HOURS=6

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

