# ============================================================
# AERIE — Environment Configuration (EXAMPLE)
# Copy this file to .env and fill in the real values.
# ============================================================

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_ENV=development
APP_NAME=Wakeel
APP_VERSION=0.1.0
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────
# Backend Security — JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────
JWT_SECRET_KEY=change-me-generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7
CONFIRMATION_TOKEN_TTL_MINUTES=10

# ─────────────────────────────────────────
# Supabase — Main DB Connection (Read-Write)
# Shared Pooler — for the app (FastAPI async)
# From: Supabase Dashboard → Project Settings → Database → Connection String
# ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Direct Connection — for migrations and seeds (bypasses PgBouncer)
DATABASE_URL_DIRECT=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase Connection Details
SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_PASSWORD=change-me

# ─────────────────────────────────────────
# Supabase Read-Only DB User (M1 Agent — SELECT only)
# In Supabase Pooler, username format: user.project-ref
# ─────────────────────────────────────────
READONLY_DB_URL=postgresql+asyncpg://erp_readonly.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────
# Supabase API Keys
# From: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────
# OpenAI
# From: platform.openai.com → API Keys
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# Embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSION=1536

# ─────────────────────────────────────────
# ElevenLabs (Speech-to-Speech / TTS)
# From: elevenlabs.io → Profile → API Keys
# ─────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...

# ─────────────────────────────────────────
# LangChain / LangSmith (Tracing & Debugging)
# From: smith.langchain.com → Settings → API Keys
# ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=Wakeel
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─────────────────────────────────────────
# Tax RAG (M1 Sprint 4 — pgvector)
# ─────────────────────────────────────────
TAX_DOCS_PATH=./data/tax_knowledge_base
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.75

# ─────────────────────────────────────────
# M2 — n8n Webhooks
# URL of the n8n webhook that receives approved RFQs
# ─────────────────────────────────────────
N8N_RFQ_WEBHOOK_URL=http://localhost:5678/webhook-test/your-webhook-id

# ─────────────────────────────────────────
# M3 — Audit Trail & Human Review
# ─────────────────────────────────────────
M3_REPEAT_ISSUE_THRESHOLD=2
M3_CONFIDENCE_REVIEW_THRESHOLD=0.70

# ─────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─────────────────────────────────────────
# Redis (optional in MVP)
# ─────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# SESSION_TTL_MINUTES=60
