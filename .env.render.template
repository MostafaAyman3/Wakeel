# Wakeel Backend — Render Environment Variables
# Set these in Render Dashboard: Your Service → Environment
# ─────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════
# REQUIRED — Backend will not start without these
# ══════════════════════════════════════════════════════════

# Supabase PostgreSQL — Shared Pooler (asyncpg, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Supabase Read-Only User — M1 Agent (SELECT only)
READONLY_DB_URL=postgresql+asyncpg://erp_readonly.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# OpenAI API Key
OPENAI_API_KEY=sk-proj-...

# JWT Secret — MUST match NEXT_PUBLIC_JWT_SECRET on the frontend
JWT_SECRET_KEY=REPLACE_WITH_YOUR_JWT_SECRET

# Frontend URL — your Vercel deployment URL (for CORS)
FRONTEND_BASE_URL=https://wakeel.vercel.app

# ══════════════════════════════════════════════════════════
# OPTIONAL — defaults work for demo
# ══════════════════════════════════════════════════════════

APP_ENV=production
APP_NAME=Wakeel
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LangSmith Tracing (optional — set to true + provide key for observability)
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=Wakeel

# ElevenLabs TTS (optional — falls back to OpenAI TTS)
# ELEVENLABS_API_KEY=sk_...

# n8n Webhook (optional — RFQ sending simulated when empty)
# N8N_RFQ_WEBHOOK_URL=

# Mini-RAG Microservice (optional — M3 RAG degrades gracefully)
# MINI_RAG_BASE_URL=http://your-mini-rag-service:8001
