# Wakeel Frontend — Vercel Environment Variables
# Copy this file to .env.local (for local dev) or set in Vercel Dashboard.
#
# In Vercel Dashboard: Settings → Environment Variables
# ────────────────────────────────────────────────────

# Backend API URL — the Render deployment URL
# Local:  http://localhost:8000
# Render: https://wakeel-api.onrender.com  (replace with your actual URL)
NEXT_PUBLIC_API_BASE_URL=https://wakeel-api.onrender.com

# App Name
NEXT_PUBLIC_APP_NAME=Wakeel

# JWT Secret — MUST match JWT_SECRET_KEY on the backend
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXT_PUBLIC_JWT_SECRET=REPLACE_WITH_YOUR_JWT_SECRET
